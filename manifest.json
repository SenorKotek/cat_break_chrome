{
  "manifest_version": 3,
  "name": "Cat Break Overlay",
  "version": "1.0.0",
  "description": "Plays cat_break.mp4 every 30 seconds as an overlay on every page.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["cat_break.mp4"],
      "matches": ["<all_urls>"]
    }
  ]
}
